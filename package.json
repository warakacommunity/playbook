{
  "name": "masakhane-playbook",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "start": "docusaurus start",
    "start:ha": "docusaurus start --locale ha",
    "start:am": "docusaurus start --locale am",
    "start:sw": "docusaurus start --locale sw",
    "start:fr": "docusaurus start --locale fr",
    "start:pt": "docusaurus start --locale pt",
    "build": "docusaurus build",
    "swizzle": "docusaurus swizzle",
    "deploy": "yarn run build && wrangler deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "pdf:generate": "mkdir -p static/downloads && docs-to-pdf docusaurus --initialDocURLs=http://localhost:3000/AfriPlaybook/ --contentSelector=article --paginationSelector=a.pagination-nav__link--next --excludeSelectors=.theme-doc-toc-mobile,.theme-doc-footer,.theme-edit-this-page,.theme-last-updated --outputPDFFilename=static/downloads/masakhane-playbook.pdf --paperFormat=A4 --pdfMargin=20,20,20,20 --puppeteerArgs=--no-sandbox,--disable-setuid-sandbox --coverTitle='Masakhane Playbook' --coverSub='Democratizing machine translation for African languages'",
    "pdf:dev": "npm run pdf:generate",
    "pdf:built": "start-server-and-test serve http://localhost:3000/AfriPlaybook/ pdf:generate",
    "pdf": "yarn build && yarn pdf:built",
    "test": "vitest run",
    "screenshots": "playwright test --config=playwright.config.js",
    "screenshots:compress": "find static/img/screenshots -name 'd*.png' -size +20k -exec pngquant --force --quality 82-95 --speed 1 --output {} {} \\;",
    "screenshots:install": "playwright install chromium",
    "preview": "yarn run build && wrangler dev"
  },
  "dependencies": {
    "@docusaurus/core": "^3.10.1",
    "@docusaurus/plugin-ideal-image": "^3.10.1",
    "@docusaurus/plugin-pwa": "^3.10.1",
    "@docusaurus/preset-classic": "^3.10.1",
    "@easyops-cn/docusaurus-search-local": "^0.55.2",
    "@giscus/react": "^3.1.0",
    "@mdx-js/react": "^3.0.0",
    "clsx": "^2.0.0",
    "katex": "^0.16.45",
    "mammoth": "^1.12.0",
    "pdfjs-dist": "^5.7.284",
    "prism-react-renderer": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rehype-katex": "^7",
    "remark-math": "^6"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.10.1",
    "@docusaurus/types": "3.10.1",
    "@playwright/test": "^1.60.0",
    "docs-to-pdf": "^1.1.0",
    "dotenv": "^17.4.2",
    "gh-pages": "^6.3.0",
    "happy-dom": "^20.9.0",
    "serve": "^14.2.6",
    "start-server-and-test": "^2.0.0",
    "vitest": "^4.1.5",
    "wrangler": "^4.105.0"
  },
  "resolutions": {
    "webpackbar": "7.0.0"
  },
  "overrides": {
    "webpackbar": "7.0.0"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=20.0"
  },
  "packageManager": "yarn@1.22.22"
}
